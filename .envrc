use flake

# Remove the 'self' flake input symlink so the Kotlin LSP
# doesn't find duplicate sources in .direnv/flake-inputs/
for link in .direnv/flake-inputs/*; do
  target="$(readlink -f "$link")"
  if [ -f "$target/flake.nix" ] && diff -q "$target/flake.nix" flake.nix >/dev/null 2>&1; then
    rm "$link"
  fi
done
